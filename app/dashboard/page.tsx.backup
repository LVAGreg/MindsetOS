'use client';

import { useEffect, useState } from 'react';
import { useRouter } from 'next/navigation';
import {
  Menu,
  X,
  LogOut,
  User,
  ChevronDown,
  Plus,
  PanelLeftClose,
  PanelLeft,
  Brain,
  Sun,
  Moon,
  Cpu,
  Sparkles,
  MessageSquare,
  Trophy,
} from 'lucide-react';
import { useAppStore, ECOS_AGENTS, AgentId } from '@/lib/store';
import { apiClient } from '@/lib/api-client';
import ChatWindow from '@/components/ChatWindow';
import ConversationHistory from '@/components/ConversationHistory';
import MemoryDashboard from '@/components/MemoryDashboard';
import { ConversationBrowser } from '@/components/ConversationBrowser';

export default function DashboardPage() {
  const router = useRouter();
  const [hasHydrated, setHasHydrated] = useState(false);

  const {
    user,
    isAuthenticated,
    setUser,
    clearUser,
    currentAgent,
    setCurrentAgent,
    isSidebarOpen,
    toggleSidebar,
    memoryEnabled,
    setMemoryEnabled,
    widgetFormattingEnabled,
    setWidgetFormattingEnabled,
    theme,
    setTheme,
    createConversation,
    setCurrentConversation,
    currentConversation,
    currentConversationId,
    conversations,
    getConversationsByAgent,
    getAllConversations,
    loadConversations,
    loadConversationMessages,
  } = useAppStore();

  // Wait for Zustand persist to hydrate from localStorage
  useEffect(() => {
    setHasHydrated(true);
  }, []);

  // Set Rana as default agent if no agent selected
  useEffect(() => {
    if (!currentAgent && hasHydrated) {
      setCurrentAgent('general');
    }
  }, [currentAgent, hasHydrated, setCurrentAgent]);

  // Apply theme on mount
  useEffect(() => {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [theme]);

  // Navigate to /c/[id] when conversation changes
  useEffect(() => {
    if (currentConversation) {
      router.replace(`/c/${currentConversation}`, { scroll: false });
    }
  }, [currentConversation, router]);

  const [showAgentDropdown, setShowAgentDropdown] = useState(false);
  const [showModelDropdown, setShowModelDropdown] = useState(false);
  const [showUserMenu, setShowUserMenu] = useState(false);
  const [modelTab, setModelTab] = useState<'chat' | 'memory' | 'widget'>('chat'); // Model selector tab state
  const [selectedChatModel, setSelectedChatModel] = useState('anthropic/claude-sonnet-4.5');
  const [selectedMemoryModel, setSelectedMemoryModel] = useState('anthropic/claude-haiku-4.5');
  const [selectedWidgetModel, setSelectedWidgetModel] = useState('anthropic/claude-haiku-4.5');
  const [isLoading, setIsLoading] = useState(true);
  const [v7Agents, setV7Agents] = useState<any[]>([]);
  const [showConversationBrowser, setShowConversationBrowser] = useState(false);

  // AI Models configuration - Updated 2025, sorted Tier 3→2→1→FREE
  const aiModels = [
    // Tier 3 - Premium
    { id: 'anthropic/claude-sonnet-4.5', name: 'Claude Sonnet 4.5', tier: 3, description: '1M context, best reasoning' },
    { id: 'openai/gpt-5-pro', name: 'GPT-5 Pro', tier: 3, description: '400K context, frontier model' },
    { id: 'x-ai/grok-4-fast', name: 'Grok 4 Fast', tier: 3, description: '2M context, real-time' },
    { id: 'openai/o3-deep-research', name: 'o3 Deep Research', tier: 3, description: '200K context, research focused' },
    // Tier 2 - Balanced
    { id: 'google/gemini-2.5-flash-preview-09-2025', name: 'Gemini 2.5 Flash', tier: 2, description: '1M context, fast' },
    { id: 'openai/gpt-4o', name: 'GPT-4o', tier: 2, description: '128K context, balanced' },
    { id: 'anthropic/claude-haiku-4.5', name: 'Claude Haiku 4.5', tier: 2, description: '200K context, efficient' },
    // Tier 1 - Fast & Efficient
    { id: 'openai/gpt-4o-mini', name: 'GPT-4o Mini', tier: 1, description: 'Fast, cost-effective' },
    { id: 'openai/gpt-5-image-mini', name: 'GPT-5 Image Mini', tier: 1, description: '400K context, image support' },
    { id: 'google/gemini-2.5-flash-lite-preview-09-2025', name: 'Gemini 2.5 Lite', tier: 1, description: 'Ultra fast, efficient' },
  ];

  const currentChatModel = aiModels.find(m => m.id === selectedChatModel) || aiModels[0];
  const currentMemoryModel = aiModels.find(m => m.id === selectedMemoryModel) || aiModels[6]; // Claude Haiku 4.5
  const currentWidgetModel = aiModels.find(m => m.id === selectedWidgetModel) || aiModels[6]; // Claude Haiku 4.5

  // Update backend model selection based on current tab
  const handleModelChange = async (modelId: string) => {
    const modelName = aiModels.find(m => m.id === modelId)?.name || modelId;

    if (modelTab === 'chat') {
      setSelectedChatModel(modelId);
      try {
        await fetch('http://localhost:3010/api/admin/ai-models/chat_agents', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modelId })
        });
        console.log('✅ Chat model updated to:', modelName);
      } catch (error) {
        console.error('Failed to update chat model:', error);
      }
    } else if (modelTab === 'memory') {
      setSelectedMemoryModel(modelId);
      try {
        await fetch('http://localhost:3010/api/admin/ai-models/memory', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modelId })
        });
        console.log('✅ Memory model updated to:', modelName);
      } catch (error) {
        console.error('Failed to update memory model:', error);
      }
    } else if (modelTab === 'widget') {
      setSelectedWidgetModel(modelId);
      try {
        await fetch('http://localhost:3010/api/admin/ai-models/widget_formatter', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modelId })
        });
        console.log('✅ Widget formatter model updated to:', modelName);
      } catch (error) {
        console.error('Failed to update widget formatter model:', error);
      }
    }

    setShowModelDropdown(false);
  };

  // Fetch V7 agents on mount
  useEffect(() => {
    const loadV7Agents = async () => {
      try {
        const response = await fetch('http://localhost:3010/api/letta/agents');
        if (response.ok) {
          const agents = await response.json();
          console.log('✅ Loaded V7 agents:', agents);
          setV7Agents(agents);
        } else {
          console.warn('⚠️  Failed to load V7 agents, using hardcoded');
        }
      } catch (error) {
        console.error('❌ Error loading V7 agents:', error);
      }
    };

    loadV7Agents();
  }, []);

  useEffect(() => {
    // Don't check auth until store has hydrated from localStorage
    if (!hasHydrated) {
      console.log('⏳ [DASHBOARD] Waiting for hydration...');
      return;
    }

    const initializeUser = async () => {
      // Check for access token in localStorage (from persist middleware)
      const accessToken = localStorage.getItem('accessToken');

      console.log('🔍 [DASHBOARD] Auth check:', {
        hasUser: !!user,
        userEmail: user?.email,
        isAuthenticated,
        hasToken: !!accessToken
      });

      // If we have user data from persisted storage AND a valid token, trust it
      if (user && isAuthenticated && accessToken) {
        console.log('✅ Restored authenticated user from storage:', user.email);
        setIsLoading(false);
        return;
      }

      // If we have a token but no user in store, something went wrong - clear token
      if (!user && accessToken) {
        console.log('⚠️  Found orphaned access token, clearing...');
        localStorage.removeItem('accessToken');
      }

      // No auto-guest login - require proper authentication
      // If no user is authenticated, redirect to login page
      if (!user || !isAuthenticated) {
        console.log('🔒 No authenticated user - redirecting to login');
        setIsLoading(false);
        router.push('/login');
        return;
      }

      setIsLoading(false);
    };

    initializeUser();
  }, [hasHydrated, setUser, user, isAuthenticated, router]);

  // Load conversations when user is authenticated
  useEffect(() => {
    const fetchConversations = async () => {
      if (!user || !isAuthenticated) return;

      try {
        const conversations = await apiClient.getUserConversations();
        loadConversations(conversations);
        console.log(`✅ Loaded ${conversations.length} conversations from database`);

        // Restore last active conversation and agent from persisted state
        const store = useAppStore.getState();
        if (store.currentConversationId && store.currentAgent) {
          console.log(`🔄 Restoring last session: Agent=${store.currentAgent}, Conversation=${store.currentConversationId}`);
          setCurrentConversation(store.currentConversationId);
          setCurrentAgent(store.currentAgent);
        } else if (conversations.length > 0) {
          // If no saved state, load the most recent conversation
          const mostRecent = conversations[0];
          console.log(`📂 Loading most recent conversation: ${mostRecent.id}`);
          setCurrentConversation(mostRecent.id);
          setCurrentAgent(mostRecent.agentId);
        }
      } catch (error) {
        console.error('❌ Failed to load conversations:', error);
      }
    };

    fetchConversations();
  }, [user, isAuthenticated, loadConversations, setCurrentConversation, setCurrentAgent]);

  // Load messages when conversation changes
  useEffect(() => {
    const loadMessages = async () => {
      if (!currentConversationId) return;

      const conversation = conversations[currentConversationId];
      if (!conversation) return;

      // Only load if messages aren't already loaded
      if (conversation.messages && conversation.messages.length > 0) {
        console.log(`✅ Messages already loaded for conversation ${currentConversationId}`);
        return;
      }

      try {
        console.log(`📨 Loading messages for conversation ${currentConversationId}...`);
        const messages = await apiClient.getConversationMessages(currentConversationId);
        loadConversationMessages(currentConversationId, messages);
      } catch (error) {
        console.error(`❌ Failed to load messages for conversation ${currentConversationId}:`, error);
      }
    };

    loadMessages();
  }, [currentConversationId]);

  const handleLogout = async () => {
    try {
      // Try to call backend logout, but don't block if it fails
      await apiClient.logout();
    } catch (error) {
      console.error('Backend logout failed (continuing anyway):', error);
    } finally {
      // Clear user state
      clearUser();
      // Only clear auth token, keep other persisted data (theme, etc.)
      localStorage.removeItem('accessToken');
      router.push('/login');
    }
  };

  const handleSelectAgent = (agentId: string) => {
    setCurrentAgent(agentId as AgentId);
    setShowAgentDropdown(false);

    // For general agent, get ALL conversations; for specific agents, filter by agent
    const agentConversations = agentId === 'general'
      ? getAllConversations()
      : getConversationsByAgent(agentId);

    if (agentConversations.length > 0) {
      // Switch to the most recent conversation (sorted by updatedAt)
      const mostRecent = agentConversations.sort(
        (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime()
      )[0];
      setCurrentConversation(mostRecent.id);
      console.log(`📂 Switched to existing conversation: ${mostRecent.id}`);
    } else {
      // No conversations exist, create a new one
      const newConvId = createConversation(agentId);
      setCurrentConversation(newConvId);
      console.log(`✨ Created new conversation: ${newConvId}`);
    }
  };

  const handleNewConversation = () => {
    if (!currentAgentData) return;
    const newConvId = createConversation(currentAgentData.id);
    setCurrentConversation(newConvId);
  };

  // Logical agent sequence for ECOS workflow
  const agentSequence = [
    'general',
    'client-onboarding',
    'money-model-maker',
    'fast-fix-finder',
    'offer-promo-printer',
    'promo-planner',
    'qualification-call-builder',
    'linkedin-events-builder-buddy'
  ];

  // Use V7 agents if available, otherwise fallback to hardcoded
  const rawAgents = v7Agents.length > 0
    ? v7Agents.map(a => ({
        id: a.id,
        name: a.name,
        description: a.description,
        icon: a.icon,
        isV7: true
      }))
    : Object.entries(ECOS_AGENTS).map(([key, agent]) => ({
        id: agent.id,
        name: agent.name,
        description: agent.description,
        icon: agent.icon,
        isV7: false
      }));

  // Sort agents according to logical sequence
  const displayAgents = rawAgents.sort((a, b) => {
    const indexA = agentSequence.indexOf(a.id);
    const indexB = agentSequence.indexOf(b.id);

    // If agent not in sequence, put it at the end
    if (indexA === -1 && indexB === -1) return 0;
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;

    return indexA - indexB;
  });

  const currentAgentData = currentAgent
    ? (v7Agents.length > 0
        ? v7Agents.find(a => a.id === currentAgent)
        : ECOS_AGENTS[currentAgent])
    : null;

  if (isLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
        <div className="text-center">
          <div className="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
          <p className="text-gray-600 dark:text-gray-400">Loading...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="h-screen flex bg-gray-50 dark:bg-gray-900">
      {/* Mobile Overlay */}
      {isSidebarOpen && (
        <div
          className="fixed inset-0 bg-black/50 z-20 md:hidden"
          onClick={toggleSidebar}
        />
      )}

      {/* Sidebar - Expanded */}
      {isSidebarOpen && (
        <div className="w-72 bg-[#1c1b1c] text-white flex flex-col md:relative absolute inset-y-0 left-0 z-30" style={{backgroundImage: "radial-gradient(rgba(253, 198, 41, 0) 49%, rgba(253, 198, 41, 0.1) 100%), url(https://expertproject.com/wp-content/uploads/2023/06/bg-arrowsv2-2@2x.png), url(https://expertproject.com/wp-content/uploads/2023/06/bg-arrowsv2-1@2x.png), linear-gradient(rgb(16, 15, 16) 0%, rgb(16, 15, 16) 15%, rgba(16, 15, 16, 0.95) 39%)", backgroundPosition: "0px 0px, 100% 100%, 0px 100%, 0px 0px", backgroundRepeat: "no-repeat", backgroundSize: "100%, 360px, 460px, 100%"}}>
          {/* Sidebar Header */}
          <div className="p-4 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
            <div className="flex items-center justify-between mb-4">
              <div className="flex items-center gap-3">
                <img
                  src="/expertas-logo.png"
                  alt="Expert OS Logo"
                  className="h-12 w-auto dark:brightness-0 dark:invert"
                />
                <span className="text-2xl font-bold text-gray-900 dark:text-white">ExpertOS</span>
              </div>
              {/* Collapse Button */}
              <button
                onClick={toggleSidebar}
                className="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
                title="Collapse sidebar"
              >
                <PanelLeftClose className="w-5 h-5 text-gray-600 dark:text-gray-400" />
              </button>
            </div>

            {/* New Conversation Button */}
            <button
              onClick={handleNewConversation}
              disabled={!currentAgent}
              className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-[#ffc82c] hover:bg-[#f8c824] text-black font-semibold rounded-lg transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed mb-2"
              title="Start a new conversation"
            >
              <Plus className="w-5 h-5" />
              <span className="text-sm font-medium">New Conversation</span>
            </button>

            {/* Browse Agents Button */}
            <button
              onClick={() => router.push('/agents')}
              className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors font-medium border border-purple-500 mb-2"
              title="Browse all agents"
            >
              <Sparkles className="w-5 h-5" />
              <span className="text-sm">Browse Agents</span>
            </button>

            {/* Search Chats Button */}
            <button
              onClick={() => setShowConversationBrowser(true)}
              className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium border border-gray-600 mb-2"
              title="Search all conversations"
            >
              <MessageSquare className="w-5 h-5" />
              <span className="text-sm">Search Chats</span>
            </button>

            {/* Assets Button - Only for power_user and admin */}
            {(user?.role === 'power_user' || user?.role === 'admin') && (
              <button
                onClick={() => router.push('/assets')}
                className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-[#ffc82c] to-yellow-500 hover:from-yellow-500 hover:to-[#ffc82c] text-black rounded-lg transition-colors font-medium border border-yellow-600 mb-2"
                title="View your assets and deliverables (things agents helped you create)"
              >
                <Trophy className="w-5 h-5" />
                <span className="text-sm font-semibold">Assets</span>
              </button>
            )}
          </div>

          {/* Conversation History */}
          <div className="flex-1 overflow-y-auto">
            <ConversationHistory currentAgentData={currentAgentData} />
          </div>

          {/* Sidebar Footer - Removed user menu (now in top-right) */}
          <div className="p-4 border-t border-gray-800/50">
            {/* Empty footer for future sidebar controls */}
          </div>
        </div>
      )}

      {/* Sidebar - Collapsed (Hidden on mobile) */}
      {!isSidebarOpen && (
        <div className="hidden md:flex w-16 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex-col items-center py-4 gap-4">
          {/* Logo */}
          <button
            onClick={toggleSidebar}
            className="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            title="Expand sidebar"
          >
            <img
              src="/expertas-logo.png"
              alt="Expert OS Logo"
              className="h-8 w-auto dark:brightness-0 dark:invert"
            />
          </button>

          {/* New Conversation Button */}
          <button
            onClick={handleNewConversation}
            disabled={!currentAgent}
            className="p-3 bg-[#ffc82c] hover:bg-[#f8c824] text-black rounded-lg transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
            title="Start a new conversation"
          >
            <Plus className="w-5 h-5" />
          </button>
        </div>
      )}

      {/* Main Content */}
      <div className="flex-1 flex flex-col">
        {/* Top Header - ChatGPT Style */}
        <header className="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-800/50 px-4 py-3 flex items-center justify-between">
          <div className="flex items-center gap-3">
            {/* Mobile Menu Button */}
            <button
              onClick={toggleSidebar}
              className="md:hidden p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
              title="Toggle menu"
            >
              <Menu className="w-6 h-6 text-gray-600 dark:text-gray-400" />
            </button>

            {/* Agent Dropdown - ChatGPT Style Model Selector */}
            <div className="relative">
              <button
                onClick={() => setShowAgentDropdown(!showAgentDropdown)}
                className="flex items-center gap-3 px-5 py-3 bg-gradient-to-r from-amber-50 to-yellow-50 dark:from-[#ffc82c]/20 dark:to-[#f8c824]/20 hover:from-amber-100 hover:to-yellow-100 dark:hover:from-[#ffc82c]/30 dark:hover:to-[#f8c824]/30 border-2 border-[#ffc82c] dark:border-[#ffc82c] rounded-xl transition-all shadow-sm hover:shadow-md min-w-[280px]"
              >
                <span className="text-2xl">{currentAgentData?.icon || '🤖'}</span>
                <div className="flex-1 text-left">
                  <div className="text-xs text-[#f8c824] dark:text-[#ffc82c] font-semibold uppercase tracking-wide mb-0.5">
                    Current Agent
                  </div>
                  <div className="text-sm font-bold text-gray-900 dark:text-white">
                    {currentAgentData?.name || 'Select an Agent'}
                  </div>
                </div>
                <ChevronDown className={`w-5 h-5 text-[#f8c824] dark:text-[#ffc82c] transition-transform ${showAgentDropdown ? 'rotate-180' : ''}`} />
              </button>

              {/* Dropdown Menu */}
              {showAgentDropdown && (
                <>
                  <div
                    className="fixed inset-0 z-10"
                    onClick={() => setShowAgentDropdown(false)}
                  />
                  <div className="absolute top-full left-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-800/50 z-20 max-h-[500px] overflow-y-auto">
                    <div className="p-2">
                      <div className="px-3 py-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">
                        Expert OS Agents {v7Agents.length > 0 && <span className="text-green-500">(V7)</span>}
                      </div>
                      {displayAgents
                        .filter((agent) => agent.id !== currentAgent)
                        .map((agent) => {
                          return (
                            <button
                              key={agent.id}
                              onClick={() => handleSelectAgent(agent.id)}
                              className="w-full flex items-start gap-3 px-3 py-3 rounded-lg transition-all text-left hover:bg-gray-50 dark:hover:bg-gray-700/50 border-2 border-transparent"
                            >
                              <span className="text-2xl">{agent.icon}</span>
                              <div className="flex-1 min-w-0">
                                <div className="text-sm font-medium text-gray-900 dark:text-white mb-1">
                                  {agent.name}
                                </div>
                                <div className="text-xs text-gray-600 dark:text-gray-400 line-clamp-2">
                                  {agent.description}
                                </div>
                              </div>
                            </button>
                          );
                        })}

                      {/* View All Agents Link */}
                      <div className="border-t border-gray-200 dark:border-gray-700 mt-2 pt-2">
                        <button
                          onClick={() => router.push('/agents')}
                          className="w-full flex items-center justify-center gap-2 px-3 py-3 rounded-lg transition-all text-center hover:bg-[#ffc82c]/10 dark:hover:bg-[#ffc82c]/20"
                        >
                          <Sparkles className="w-4 h-4 text-[#ffc82c]" />
                          <span className="text-sm font-semibold text-[#ffc82c]">
                            View All Agents →
                          </span>
                        </button>
                      </div>
                    </div>
                  </div>
                </>
              )}
            </div>

            {/* AI Model Selector - Only for power_user and admin */}
            {(user?.role === 'power_user' || user?.role === 'admin') && (
              <div className="relative">
                <button
                  onClick={() => setShowModelDropdown(!showModelDropdown)}
                  className="flex items-center gap-2 px-4 py-2 bg-purple-50 dark:bg-purple-900/30 hover:bg-purple-100 dark:hover:bg-purple-900/50 border border-purple-200 dark:border-purple-700 rounded-lg transition-colors"
                  title={`Current Model: ${currentChatModel.name}`}
                >
                  <Cpu className="w-4 h-4 text-purple-600 dark:text-purple-400" />
                  <span className="text-sm font-medium text-gray-900 dark:text-white">
                    {currentChatModel.name}
                  </span>
                  <ChevronDown className={`w-4 h-4 text-purple-600 dark:text-purple-400 transition-transform ${showModelDropdown ? 'rotate-180' : ''}`} />
                </button>

                {/* Model Dropdown */}
                {showModelDropdown && (
                  <>
                    <div
                      className="fixed inset-0 z-10"
                      onClick={() => setShowModelDropdown(false)}
                    />
                    <div className="absolute top-full left-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-800/50 z-20 max-h-[500px] overflow-y-auto">
                      {/* Model Type Tabs */}
                      <div className="flex border-b border-gray-200 dark:border-gray-700 p-2 gap-1">
                        <button
                          onClick={() => setModelTab('chat')}
                          className={`flex-1 px-3 py-2 text-xs font-semibold rounded-lg transition-all ${
                            modelTab === 'chat'
                              ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400'
                              : 'text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'
                          }`}
                        >
                          💬 Chat
                        </button>
                        <button
                          onClick={() => setModelTab('memory')}
                          className={`flex-1 px-3 py-2 text-xs font-semibold rounded-lg transition-all ${
                            modelTab === 'memory'
                              ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400'
                              : 'text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'
                          }`}
                        >
                          🧠 Memory
                        </button>
                        <button
                          onClick={() => setModelTab('widget')}
                          className={`flex-1 px-3 py-2 text-xs font-semibold rounded-lg transition-all ${
                            modelTab === 'widget'
                              ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400'
                              : 'text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'
                          }`}
                        >
                          ✨ Widget
                        </button>
                      </div>

                      <div className="p-2">
                        <div className="px-3 py-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">
                          {modelTab === 'chat' ? 'Chat Models' : modelTab === 'memory' ? 'Memory Models' : 'Widget Formatter Models'}
                        </div>
                        {aiModels.map((model) => {
                          const isActive = modelTab === 'chat'
                            ? selectedChatModel === model.id
                            : modelTab === 'memory'
                            ? selectedMemoryModel === model.id
                            : selectedWidgetModel === model.id;

                          return (
                            <button
                              key={model.id}
                              onClick={() => handleModelChange(model.id)}
                              className={`w-full flex items-start gap-3 px-3 py-3 rounded-lg transition-all text-left ${
                                isActive
                                  ? 'bg-purple-50 dark:bg-purple-900/20 border-2 border-purple-500'
                                  : 'hover:bg-gray-50 dark:hover:bg-gray-700/50 border-2 border-transparent'
                              }`}
                            >
                              <Cpu className={`w-5 h-5 mt-0.5 ${isActive ? 'text-purple-600 dark:text-purple-400' : 'text-gray-400'}`} />
                              <div className="flex-1 min-w-0">
                                <div className="flex items-center gap-2 mb-1">
                                  <div className="text-sm font-medium text-gray-900 dark:text-white">
                                    {model.name}
                                  </div>
                                  <span className={`text-xs px-2 py-0.5 rounded-full font-semibold ${
                                    model.tier === 3
                                      ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400'
                                      : model.tier === 2
                                      ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400'
                                      : 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400'
                                  }`}>
                                    Tier {model.tier}
                                  </span>
                                </div>
                                <div className="text-xs text-gray-600 dark:text-gray-400">
                                  {model.description}
                                </div>
                              </div>
                            </button>
                          );
                        })}
                      </div>
                    </div>
                  </>
                )}
              </div>
            )}
          </div>

          {/* Right Side - Expert OS Title + Controls */}
          <div className="flex items-center gap-4">
            {/* Theme Toggle */}
            <button
              onClick={() => setTheme(theme === 'dark' ? 'light' : 'dark')}
              className="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
              aria-label="Toggle theme"
              title={theme === 'dark' ? 'Switch to Light Mode' : 'Switch to Dark Mode'}
            >
              {theme === 'dark' ? (
                <Sun className="w-5 h-5 text-yellow-500" />
              ) : (
                <Moon className="w-5 h-5 text-gray-700" />
              )}
            </button>

            {/* Memory Toggle - Only for power_user and admin */}
            {(user?.role === 'power_user' || user?.role === 'admin') && (
              <div className="flex items-center gap-2">
                <Brain className={`w-5 h-5 ${memoryEnabled ? 'text-[#f8c824] dark:text-[#ffc82c]' : 'text-gray-400'}`} />
                <button
                  onClick={() => setMemoryEnabled(!memoryEnabled)}
                  className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${
                    memoryEnabled ? 'bg-blue-600' : 'bg-gray-300 dark:bg-gray-600'
                  }`}
                  aria-label="Toggle memory"
                  title={memoryEnabled ? 'Memory: ON' : 'Memory: OFF'}
                >
                  <span
                    className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${
                      memoryEnabled ? 'translate-x-6' : 'translate-x-1'
                    }`}
                  />
                </button>
                <span className="text-xs font-medium text-gray-600 dark:text-gray-400">
                  {memoryEnabled ? 'ON' : 'OFF'}
                </span>
              </div>
            )}

            {/* Widget Formatting Toggle - Only for power_user and admin */}
            {(user?.role === 'power_user' || user?.role === 'admin') && (
              <div className="flex items-center gap-2">
                <Sparkles className={`w-5 h-5 ${widgetFormattingEnabled ? 'text-purple-500 dark:text-purple-400' : 'text-gray-400'}`} />
                <button
                  onClick={() => setWidgetFormattingEnabled(!widgetFormattingEnabled)}
                  className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${
                    widgetFormattingEnabled ? 'bg-purple-600' : 'bg-gray-300 dark:bg-gray-600'
                  }`}
                  aria-label="Toggle widget formatting"
                  title={widgetFormattingEnabled ? 'Widget Formatting: ON' : 'Widget Formatting: OFF'}
                >
                  <span
                    className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${
                      widgetFormattingEnabled ? 'translate-x-6' : 'translate-x-1'
                    }`}
                  />
                </button>
                <span className="text-xs font-medium text-gray-600 dark:text-gray-400">
                  {widgetFormattingEnabled ? 'ON' : 'OFF'}
                </span>
              </div>
            )}
          </div>
        </header>

        {/* Chat Area */}
        <div className="flex-1 overflow-hidden">
          {currentAgent ? (
            <ChatWindow agentId={currentAgent} />
          ) : (
            <div className="h-full flex items-center justify-center p-8">
              <div className="text-center max-w-2xl">
                <div className="mb-6 flex justify-center">
                  <img
                    src="/expertas-logo.png"
                    alt="Expert OS Logo"
                    className="h-24 w-auto dark:brightness-0 dark:invert"
                  />
                </div>
                <h2 className="text-3xl font-bold text-gray-900 dark:text-white mb-4">
                  Welcome to Expert OS
                </h2>
                <p className="text-gray-600 dark:text-gray-400 mb-8 text-lg leading-relaxed">
                  Expert Consulting Operating System - Rana Agent is ready to help you build your consulting business systematically.
                </p>
                <button
                  onClick={() => setShowAgentDropdown(true)}
                  className="px-6 py-3 bg-[#ffc82c] text-black rounded-xl hover:bg-[#f8c824] transition-colors shadow-md hover:shadow-lg font-semibold"
                >
                  Choose Your Agent
                </button>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Memory Analytics Drawer - slides in from right - Only for power_user and admin */}
      {(user?.role === 'power_user' || user?.role === 'admin') && <MemoryDashboard />}

      {/* Conversation Browser Modal */}
      <ConversationBrowser
        isOpen={showConversationBrowser}
        onClose={() => setShowConversationBrowser(false)}
        onSelectConversation={(conversationId) => {
          setCurrentConversation(conversationId);
          setShowConversationBrowser(false);
          // Switch to the agent for that conversation
          const conv = conversations[conversationId];
          if (conv) {
            setCurrentAgent(conv.agentId as AgentId);
          }
        }}
      />
    </div>
  );
}
