// ECOS Database Schema
// PostgreSQL with pgvector for semantic search

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================
// User Management
// ============================================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String?  @map("first_name") @db.VarChar(100)
  lastName     String?  @map("last_name") @db.VarChar(100)
  role         UserRole @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  conversations    Conversation[]
  memories         Memory[]
  artifacts        Artifact[]
  analyticsEvents  AnalyticsEvent[]
  questionFlowStates QuestionFlowState[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================
// Agent Management
// ============================================

model Agent {
  id              String   @id @db.VarChar(100) // e.g., "money-model-maker"
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  systemPrompt    String   @map("system_prompt") @db.Text
  capabilities    Json?    @db.JsonB
  modelPreference String   @default("gpt-5") @map("model_preference") @db.VarChar(50)
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2000) @map("max_tokens")
  questionFlowId  String?  @map("question_flow_id") @db.Uuid
  knowledgeBaseIds String[] @map("knowledge_base_ids") @db.Uuid
  isActive        Boolean  @default(true) @map("is_active")
  metadata        Json?    @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  conversations    Conversation[]
  memories         Memory[]
  artifacts        Artifact[]
  questionFlow     QuestionFlow?     @relation(fields: [questionFlowId], references: [id])
  trainingExamples TrainingExample[]
  analyticsEvents  AnalyticsEvent[]

  @@map("agents")
}

// ============================================
// Conversations & Messages
// ============================================

model Conversation {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  agentId        String             @map("agent_id") @db.VarChar(100)
  title          String?            @db.VarChar(255)
  status         ConversationStatus @default(ACTIVE)
  messageCount   Int                @default(0) @map("message_count")
  lastMessageAt  DateTime?          @map("last_message_at") @db.Timestamp()
  metadata       Json?              @db.JsonB
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamp()
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent              Agent               @relation(fields: [agentId], references: [id])
  messages           Message[]
  artifacts          Artifact[]
  questionFlowStates QuestionFlowState[]

  @@index([userId])
  @@index([agentId])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String   @db.Text
  attachments    Json?    @db.JsonB
  metadata       Json?    @db.JsonB // model, tokens, artifacts
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ============================================
// Memory Layer (Mem0 Integration)
// ============================================

model Memory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  agentId   String?  @map("agent_id") @db.VarChar(100)
  content   String   @db.Text
  embedding Unsupported("vector(1536)")? // pgvector for semantic search
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@map("memories")
}

// ============================================
// Artifacts (Generated Outputs)
// ============================================

model Artifact {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  agentId        String   @map("agent_id") @db.VarChar(100)
  type           String   @db.VarChar(50) // money-model, fast-fix, promo-copy, etc.
  title          String?  @db.VarChar(255)
  data           Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  agent        Agent         @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("artifacts")
}

// ============================================
// Knowledge Base Management
// ============================================

model KnowledgeBase {
  id              String                @id @default(uuid()) @db.Uuid
  name            String                @db.VarChar(255)
  description     String?               @db.Text
  agentIds        String[]              @map("agent_ids") @db.VarChar(100)
  documentCount   Int                   @default(0) @map("document_count")
  embeddingStatus KnowledgeEmbedStatus  @default(PENDING) @map("embedding_status")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamp()
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  documents Document[]

  @@map("knowledge_bases")
}

enum KnowledgeEmbedStatus {
  PENDING
  PROCESSING
  COMPLETE
  ERROR
}

model Document {
  id              String                @id @default(uuid()) @db.Uuid
  knowledgeBaseId String                @map("knowledge_base_id") @db.Uuid
  title           String                @db.VarChar(255)
  content         String                @db.Text
  fileType        String?               @map("file_type") @db.VarChar(20)
  fileSize        Int?                  @map("file_size")
  metadata        Json?                 @db.JsonB
  embeddingStatus KnowledgeEmbedStatus  @default(PENDING) @map("embedding_status")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  knowledgeBase KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id         String                           @id @default(uuid()) @db.Uuid
  documentId String                           @map("document_id") @db.Uuid
  content    String                           @db.Text
  embedding  Unsupported("vector(1536)")?     // pgvector
  chunkIndex Int                              @map("chunk_index")
  metadata   Json?                            @db.JsonB
  createdAt  DateTime                         @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

// ============================================
// Question Flows (Guided Conversations)
// ============================================

model QuestionFlow {
  id          String   @id @default(uuid()) @db.Uuid
  agentId     String?  @map("agent_id") @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  questions   Json     @db.JsonB // Array of Question objects
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  agents Agent[]
  states QuestionFlowState[]

  @@map("question_flows")
}

model QuestionFlowState {
  id                String   @id @default(uuid()) @db.Uuid
  flowId            String   @map("flow_id") @db.Uuid
  conversationId    String   @map("conversation_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  currentQuestionId String?  @map("current_question_id") @db.VarChar(100)
  answers           Json?    @db.JsonB // questionId -> answer map
  isComplete        Boolean  @default(false) @map("is_complete")
  completedAt       DateTime? @map("completed_at") @db.Timestamp()
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  flow         QuestionFlow @relation(fields: [flowId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("question_flow_states")
}

// ============================================
// Training Examples
// ============================================

model TrainingExample {
  id             String   @id @default(uuid()) @db.Uuid
  agentId        String   @map("agent_id") @db.VarChar(100)
  input          String   @db.Text
  expectedOutput String   @map("expected_output") @db.Text
  category       String?  @db.VarChar(100)
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  agent Agent @relation(fields: [agentId], references: [id])

  @@map("training_examples")
}

// ============================================
// Analytics
// ============================================

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  agentId   String?  @map("agent_id") @db.VarChar(100)
  eventType String   @map("event_type") @db.VarChar(50)
  eventData Json?    @map("event_data") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user  User?  @relation(fields: [userId], references: [id])
  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}
